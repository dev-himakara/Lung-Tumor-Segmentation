    "test_dataset  = LIDCPatchDataset(test_df, PATCH_DIR, MASK_DIR, train=False)\n",
    "\n",
    "train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True, num_workers=0)\n",
