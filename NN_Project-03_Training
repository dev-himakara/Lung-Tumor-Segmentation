    "def dice_metric(pred, target, eps=1e-6):\n",
    "    pred = (torch.sigmoid(pred) > 0.5).float()\n",
    "    num = 2 * (pred * target).sum(dim=(2,3)) + eps\n",
    "    den = pred.sum(dim=(2,3)) + target.sum(dim=(2,3)) + eps\n",
    "    dice = num / den\n",
    "    return dice.mean().item()"
   ]
